function print_image() {
	local BASE_URL="$1"
	local PATTERN="$2"

	local DATA;
	DATA=$(curl -L -s "${BASE_URL}/?jsontable" |
		jq -r ".data[] | select(.name|test(\"${PATTERN}\")) | \"\(.name) \(.size) \(.mtime)\"" |
		sort -V | tail -n 1)

	if [ -z "$DATA" ]; then
		red "  ISO image not found"
	else
		# split the image name, size and modification time
		local NAME
		NAME=$(echo "$DATA" | awk '{print $1}')
		local SIZE
		SIZE=$(echo "$DATA" | awk '{print $2}')
		local MTIME
		MTIME=$(echo "$DATA" | awk '{print $3}')

		local HUMAN_SIZE
		# format the size to kiB/MiB/... as needed
		HUMAN_SIZE=$(numfmt --to=iec-i --suffix=B "$SIZE")
		local DATE
		DATE=$(date -d "@$MTIME" +"%Y-%m-%d %H:%M:%S")
		local REL_TIME
		REL_TIME=$(relative_time "$MTIME")

		if [ "$HYPERLINKS" = "true" ]; then
			# print the ISO URL as a clickable link
			printf "  ISO: \e]8;;%s%s\e\\%s%s%s\e]8;;\e\\ (%s, %s - %s)\n" \
				"$BASE_URL" "$NAME" "$YELLOW" "$NAME" "$NC" "$HUMAN_SIZE" "$DATE" "$REL_TIME"
		else
			# display a plain link
			echo "  ISO: ${YELLOW}${BASE_URL}${NAME}${NC} ($HUMAN_SIZE, $DATE - $REL_TIME)"
		fi
	fi
}

function latest_version() {
	local BASE_URL="$1"
	local PATTERN="$2"

	curl -L -s "${BASE_URL}/?jsontable" | jq -r ".data[] | select(.name|test(\"${PATTERN}\")) | .name" | sort -V | tail -n 1
}

function get_branches() {
	curl -L -s -H "accept: application/json" "https://build.opensuse.org/project/subprojects/systemsmanagement:Agama?type=subproject&length=1000" |
		jq -r ".data[] | select(.name|test(\"systemsmanagement:Agama:branches:\")) | .name " | sort |
		sed -e "s/.*systemsmanagement:Agama:branches:\([^<]\+\).*/\\1/"
}

function list_branches() {
	readarray -t BRANCHES < <(get_branches)
	for BRANCH in "${BRANCHES[@]}"; do
		echo
		printf "  ID: "
		green "devel-branch-${BRANCH}"
		echo "  Description: The experimental image from systemsmanagement:Agama:branches:${BRANCH} project"
		print_image "https://download.opensuse.org/repositories/systemsmanagement:/Agama:/branches:/${BRANCH}/images/iso/" \
			"${ARCH}-.*-openSUSE-Build.*\\\\.iso\$"
	done
}

function verify_signature_with_keyring() {
	local KEYRING="$1"
	if gpg --no-default-keyring --keyring "$KEYRING" --verify "$GPG_FILE" "$CHECKSUM_FILE"; then
		green "GPG signature OK"
	else
		red "GPG signature verification failed, the file might be corrupted."
		exit 1
	fi
}

function verify_checksum_and_signature() {
	if [ -n "$CHECKSUM_DOWNLOAD_URL" ]; then
		CHECKSUM_URL="${CHECKSUM_DOWNLOAD_URL}"
		CHECKSUM_FILE="${CHECKSUM_DOWNLOAD_URL##*/}"
		GPG_URL=""
		GPG_FILE=""
	else
		CHECKSUM_URL="${URL}.sha256"
		CHECKSUM_FILE="${URL##*/}.sha256"
		GPG_URL="${CHECKSUM_URL}.asc"
		GPG_FILE="${CHECKSUM_FILE}.asc"
	fi

	echo "Downloading checksum ${CHECKSUM_FILE}..."
	curl -s -L -O "$CHECKSUM_URL"

	# remove the lines from the checksum file which do not match the current image
	sed -i "/${URL##*/}$/!d" "$CHECKSUM_FILE"

	if [ -n "$GPG_URL" ]; then
		echo "Downloading GPG signature ${GPG_FILE}..."
		curl -s -L -O "$GPG_URL"
	fi

	if [ -n "$GPG_FILE" ]; then
		# check if the GPG key is already imported
		KEY_ID=$(LC_ALL=C gpg --verify "$GPG_FILE" "$CHECKSUM_FILE" 2>&1 | grep "using RSA key" | sed -e "s/.*using RSA key \([0-9A-F]\+\).*/\\1/")
		if gpg --list-keys "$KEY_ID" >/dev/null 2>&1; then
			echo "Verifying GPG signature..."
			if gpg --verify "$GPG_FILE" "$CHECKSUM_FILE"; then
				green "GPG signature OK"
			else
				red "GPG signature verification failed, the file might be corrupted."
				exit 1
			fi
		else
			if [ -n "$GPG_DOWNLOAD_URL" ]; then
				echo "Downloading GPG key from ${GPG_DOWNLOAD_URL}..."
				TEMP_KEYRING=$(mktemp --tmpdir keyring.XXXXXXXX)
				echo "Importing GPG key from $GPG_DOWNLOAD_URL into a temporary keyring"
				curl -s "$GPG_DOWNLOAD_URL" | gpg --no-default-keyring --keyring "$TEMP_KEYRING" --import

				verify_signature_with_keyring "$TEMP_KEYRING"
			else
				# if the GPG key is not known then try extracting it from the RPM database
				SHORT_KEY_ID=$(echo "$KEY_ID" | tail -c 9 | tr "[:upper:]" "[:lower:]")
				RPM_KEY=$(rpm -qa "gpg-pubkey" | grep "gpg-pubkey-${SHORT_KEY_ID}") || true

				if [ -n "$RPM_KEY" ]; then
					TEMP_KEYRING=$(mktemp --tmpdir keyring.XXXXXXXX)
					echo "Importing GPG key $RPM_KEY from the RPM database into a temporary keyring"
					rpm -q --queryformat "%{DESCRIPTION}" "$RPM_KEY" | gpg --no-default-keyring --keyring "$TEMP_KEYRING" --import
					verify_signature_with_keyring "$TEMP_KEYRING"
				else
					# the openSUSE or SUSE keys can be imported also from the GPG servers
					if [ "$KEY_ID" = "35A2F86E29B700A4" ] || [ "$KEY_ID" = "B88B2FD43DBDC284" ] ||
						[ "$KEY_ID" = "F74F09BC3FA1D6CE" ] || [ "$KEY_ID" = "A1BFC02BD588DC46" ]; then
						TEMP_KEYRING=$(mktemp --tmpdir keyring.XXXXXXXX)
						echo "Importing GPG key $KEY_ID from GPG servers into a temporary keyring"
						gpg --no-default-keyring --keyring "$TEMP_KEYRING" --recv-keys "$KEY_ID"

						verify_signature_with_keyring "$TEMP_KEYRING"
					else
						echo "The GPG key is not known, you have to manually import the respective public key"
					fi
				fi
			fi
		fi
	fi

	echo "Verifying SHA256 checksum..."
	if sha256sum --status -c "$CHECKSUM_FILE"; then
		green "SHA256 checksum OK"
	else
		red "SHA256 checksum does not match, broken file?"
		exit 1
	fi
}

IMAGE=""

while [[ $# -gt 0 ]]; do
	case "$1" in
	--arch)
		ARCH="$2"
		shift 2
		;;
	-h | --help)
		print_help
		exit 0
		;;
	*)
		IMAGE="$1"
		shift
		;;
	esac
done

if [ -z "$IMAGE" ]; then
	print_list
	exit 0
fi


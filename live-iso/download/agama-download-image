#! /bin/bash

set -eu

ARCH=$(uname -m)
CURRENT_TIME=$(date +%s)
GPG_DOWNLOAD_URL=""
CHECKSUM_DOWNLOAD_URL=""
TEMP_KEYRING=""

function cleanup() {
	if [ -n "$TEMP_KEYRING" ] && [ -f "$TEMP_KEYRING" ]; then
		rm "$TEMP_KEYRING"
	fi
}
trap cleanup EXIT

# --- Colors and Helpers ---
# Check if stderr is a terminal and if it supports at least 8 colors
if [[ -t 2 && $(tput colors 2>/dev/null) -ge 8 ]]; then
	RED=$(tput setaf 1)
	GREEN=$(tput setaf 2)
	YELLOW=$(tput setaf 3)
	NC=$(tput sgr0) # No Color
else
	RED=""
	GREEN=""
	YELLOW=""
	NC=""
fi

# Check for terminal hyperlink support
HYPERLINKS=false
if [[ -t 1 ]]; then
	# can some other terminals display links?
	if [ "${VTE_VERSION:-0}" -ge 5000 ] ||
		[ "${TERM_PROGRAM:-}" = "vscode" ]; then
		HYPERLINKS=true
	fi
fi

red() {
	echo "${RED}${*}${NC}"
}

yellow() {
	echo "${YELLOW}${*}${NC}"
}

green() {
	echo "${GREEN}${*}${NC}"
}

function print_help() {
	echo "Usage: $0 [options] [image-id]"
	echo
	echo "Options:"
	echo "  -h, --help     Display this help and exit"
	echo "  --arch <arch>  Specify the architecture (default: ${ARCH})"
	echo
	echo "Run without arguments to see the list of available image IDs."
}

# check if the IBS server is accessible
if curl --head --silent --fail --connect-timeout 5 --max-time 5 -L "https://download.suse.de" >/dev/null; then
	IBS=true
else
	IBS=false
fi

function relative_time() {
	local DIFF=$((CURRENT_TIME - $1))

	if [[ $DIFF -lt 60 ]]; then
		echo "$DIFF seconds ago"
	elif [[ $DIFF -lt 3600 ]]; then
		echo "$((DIFF / 60)) minutes ago"
	elif [[ $DIFF -lt 86400 ]]; then
		echo "$((DIFF / 3600)) hours ago"
	else
		echo "$((DIFF / 86400)) days ago"
	fi
}

function quarterly_updates() {
	local BASE_URL="https://download.suse.de/ibs/SUSE:/SLFO:/Products:/SLES:/16.0:"
	readarray -t UPDATES < <(curl -L -s "${BASE_URL}/?jsontable" | jq -r ".data[] | select(.name|test(\"^QU[0-9]+/\$\")) | .name" | tr -d "/")
}

